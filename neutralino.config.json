{
  "applicationId": "vantoan1511.orbit",
  "applicationName": "Orbit",
  "applicationIcon": "public/icon.png",
  "description": "A fast, lightweight desktop application for exploring, monitoring, and managing Kubernetes clusters from a single intuitive interface.",
  "version": "1.0.0",
  "author": "Toan Nguyen",
  "copyright": "Copyright © Toan Nguyen 2026. All rights reserved.",
  "defaultMode": "window",
  "storageLocation": "app",
  "dataLocation": "app",
  "documentRoot": "/build/",
  "logging": {
    "enabled": true,
    "writeToLogFile": true
  },
  "port": 0,
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "singlePageServe": true,
  "enableExtensions": true,
  "tokenSecurity": "none",
  "nativeAllowList": [
    "filesystem.readDirectory",
    "extensions.getStats"
  ],
  "extensions": [
    {
      "id": "vantoan1511.orbit.core.engine",
      "commandLinux": "${NL_PATH}/core/target/release/orbit-engine",
      "commandWindows": "core\\target\\release\\orbit-engine.exe",
      "commandDarwin": "${NL_PATH}/core/target/release/orbit-engine"
    }
  ],
  "modes": {
    "window": {
      "title": "Orbit",
      "minWidth": 1280,
      "minHeight": 720,
      "center": true,
      "icon": "/public/icon.png",
      "enableInspector": true
    }
  },
  "cli": {
    "binaryName": "orbit",
    "resourcesPath": "/build/",
    "resourcesExclude": ".*\\.ts$|.*\\.tsx$|.*\\.map$",
    "extensionsPath": "/core/",
    "extensionsExclude": "",
    "binaryVersion": "6.8.0",
    "clientVersion": "6.8.0",
    "frontendLibrary": {
      "patchFile": "/index.html",
      "devUrl": "http://localhost:5173",
      "projectPath": "/",
      "initCommand": "npm install",
      "devCommand": "npm run dev",
      "buildCommand": "npm run build && cd core && cargo build --release"
    }
  }
}